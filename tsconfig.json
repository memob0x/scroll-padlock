{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext",
      "dom"
    ],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "src",
    "module": "ESNext",
    "outDir": "dist"
  },
  "include": [
    "src/*.ts"
  ],
  "exclude": [
    "src/*.spec.ts",
    "coverage",
    "node_modules",
    "dist"
  ]
}