{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "ESNext",
      "dom"
    ],
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/*.spec.ts",
    "coverage",
    "node_modules",
    "dist"
  ]
}