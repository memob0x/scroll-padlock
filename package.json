{
  "name": "scroll-padlock",
  "type": "module",
  "author": {
    "name": "memob0x",
    "url": "https://github.com/memob0x"
  },
  "description": "CSS variables-based scrollbars locker",
  "main": "./dist/umd/scroll-padlock.js",
  "module": "./dist/esm/scroll-padlock.js",
  "types": "./dist/esm/scroll-padlock.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt"
  ],
  "version": "3.0.1",
  "license": "MIT",
  "repository": "https://github.com/memob0x/scroll-padlock.git",
  "keywords": [
    "scroll-locking",
    "css-variables",
    "scrollbar-width"
  ],
  "scripts": {
    "lint": "npx eslint .",
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.umd.json",
    "test:unit": "c8 node --import tsx --test ./src/**/*.spec.ts",
    "test:e2e": "node --import tsx --test ./e2e/**/*.spec.ts",
    "test": "npm run test:unit && npm run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.5",
    "jsdom": "^29.0.1",
    "pixelmatch": "^7.1.0",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}